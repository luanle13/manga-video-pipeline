# Database Configuration
DATABASE_URL=sqlite:///./manga_pipeline.db

# Redis Configuration
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
TTS_VOICE=alloy
TTS_MODEL=tts-1

# YouTube Configuration (English)
YOUTUBE_EN_CLIENT_ID=your_en_youtube_client_id
YOUTUBE_EN_CLIENT_SECRET=your_en_youtube_client_secret
YOUTUBE_EN_CHANNEL_ID=your_en_youtube_channel_id
YOUTUBE_EN_CREDENTIALS_PATH=./credentials/youtube_en_credentials.json

# YouTube Configuration (Vietnamese)
YOUTUBE_VN_CLIENT_ID=your_vn_youtube_client_id
YOUTUBE_VN_CLIENT_SECRET=your_vn_youtube_client_secret
YOUTUBE_VN_CHANNEL_ID=your_vn_youtube_channel_id
YOUTUBE_VN_CREDENTIALS_PATH=./credentials/youtube_vn_credentials.json

# TikTok Configuration (English)
TIKTOK_EN_CLIENT_KEY=your_en_tiktok_client_key
TIKTOK_EN_CLIENT_SECRET=your_en_tiktok_client_secret
TIKTOK_EN_ACCESS_TOKEN=your_en_tiktok_access_token

# TikTok Configuration (Vietnamese)
TIKTOK_VN_CLIENT_KEY=your_vn_tiktok_client_key
TIKTOK_VN_CLIENT_SECRET=your_vn_tiktok_client_secret
TIKTOK_VN_ACCESS_TOKEN=your_vn_tiktok_access_token

# Facebook Configuration (English)
FACEBOOK_EN_PAGE_ID=your_en_facebook_page_id
FACEBOOK_EN_ACCESS_TOKEN=your_en_facebook_access_token

# Facebook Configuration (Vietnamese)
FACEBOOK_VN_PAGE_ID=your_vn_facebook_page_id
FACEBOOK_VN_ACCESS_TOKEN=your_vn_facebook_access_token

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ENABLED=false

# Manga Discovery Configuration
MANGADEX_BASE_URL=https://api.mangadex.org
MANGA_TRENDING_SOURCES="mangadex,myanimelist,mangasee"

# Video Generation Configuration
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_BITRATE=2M

# Pipeline Configuration
MAX_CHAPTERS_PER_DAY=10
VIDEO_MAX_DURATION=600
TEMP_PATH=data/temp
LANGUAGES="en,vn"
PLATFORMS="youtube,tiktok,facebook"

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=data/logs/manga_pipeline.log

# Application Configuration
MAX_CONCURRENT_TASKS=5
OUTPUT_DIR=data/output